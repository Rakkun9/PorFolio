---
const currentLang = Astro.url.pathname.startsWith('/en') ? 'en' : 'es';
---
<header class="flex justify-between items-center py-5 w-full xl:w-[1120px] mx-auto px-4 z-50 flex-wrap gap-4">

    <nav class="flex flex-row gap-x-10 opacity-80 w-full md:w-auto flex-wrap justify-center ">
        <a href="#top" class="hover:text-yellow-200 transition">{currentLang === 'en' ? "Home" : "Inicio"}</a>
        <a href="#experiencia" class="hover:text-yellow-200 transition">{currentLang === 'en' ? "Experience" : "Experiencia"}</a>
        <a href="#proyectos" class="hover:text-yellow-200 transition">{currentLang === 'en' ? "Projects" : "Proyectos"}</a>
        <a href="#contacto" class="hover:text-yellow-200 transition">{currentLang === 'en' ? "Contact" : "Contacto"}</a>
    </nav>

    <!-- Language Switcher -->
    <div class="flex gap-x-2 font-bold text-sm bg-white/10 px-3 py-1 rounded-full border border-white/10 relative z-50">
        <a href="/" class={`hover:text-yellow-200 transition px-1 ${currentLang === 'es' ? 'text-yellow-200' : ''}`}>ES</a>
        <span class="opacity-50">|</span>
        <a href="/en" class={`hover:text-yellow-200 transition px-1 ${currentLang === 'en' ? 'text-yellow-200' : ''}`}>EN</a>
    </div>
</header>