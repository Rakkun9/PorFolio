---
import Layout from "../../layouts/Layout.astro";
import Badge from "../../components/Badge.astro";
import Github from "../../icons/Github.astro";
import LinkedIn from "../../icons/LinkedIn.astro";
import Social from "../../components/Social.astro";
import Mail from "../../icons/Mail.astro";
import Experience from "../../components/Experience.astro";
import SectionContainer from "../../components/SectionContainer.astro";
import BriefCase from "../../icons/BriefCase.astro";
import Code from "../../icons/Code.astro";
import Projects from "../../components/Projects.astro";
import Contact from "../../components/Contact.astro";
import Certification from "../../components/Certification.astro";
---

<Layout
  title="Nicolay's Portfolio - Software Engineer & FullStack Developer"
  description="Hire Juan Nicolay Buitrago for the development of scalable applications, microservices, and FullStack solutions."
>
  <main class="px-4">
    <SectionContainer class="py-44 pb-32">
      <img
        class="rounded-full w-12 h-12 mb-4"
        src="https://github.com/Rakkun9.png"
        alt="Juan Nicolay Buitrago"
      />
      <h1
        class="text-white text-3xl md:text-4xl lg:text-5xl font-bold flex flex-row gap-x-4 pb-6 lg:pb-10"
      >
        Hey, I'm Nicolay <a
          href="https://www.linkedin.com/in/nicolaybuitrago"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Nicolay's LinkedIn Profile"
          class="flex justify-center items-center hover:scale-105 transition"
        >
          <Badge>Available for work</Badge></a
        >
      </h1>
      <h2 class="text-xl lg:text-2xl text-wrap max-w-[700px]">
        <span class="text-white">Over 2 years of experience.</span>
        <span class="text-yellow-200/90">
          FullStack Developer and Software Engineer in training.</span>
        <span class="text-red-200/90">
          Specialized in Microservices Architectures with Docker, Kubernetes, and Istio.
        </span>
        <span class="opacity-80">
          Passionate about building robust, efficient, and scalable technological solutions.</span>
      </h2>
      <nav class="flex gap-4 mt-8 flex-wrap">
        <Social href="https://www.linkedin.com/in/nicolaybuitrago" aria-label="LinkedIn">
          <LinkedIn class="size-4 md:size-6" />LinkedIn
        </Social>
        <Social href="https://www.github.com/Rakkun9/" aria-label="GitHub">
          <Github class="size-4 md:size-6" />Github
        </Social>
        <Social href="mailto:jnicolaybv@gmail.com" aria-label="Send an email">
          <Mail class="size-4 md:size-6" />Contact me
        </Social>
        <Social href="/CV_JuanNicolay_ATS_EN.pdf" download="CV_JuanNicolay_EN.pdf" aria-label="Download my Curriculum Vitae">
          <svg class="size-4 md:size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
          Download CV
        </Social>
      </nav>
    </SectionContainer>

    <SectionContainer id="experiencia">
      <h2 class="text-3xl font-semibold mb-6 flex gap-x-3 items-center">
        <BriefCase class="size-7" /> Work Experience
      </h2>
      <Experience lang="en" />
    </SectionContainer>
    <SectionContainer id="proyectos">
      <h2 class="text-3xl font-semibold mb-6 flex gap-x-3 items-center">
        <Code class="size-7" /> Projects
      </h2>
      <Projects lang="en" />
    </SectionContainer>
    <SectionContainer id="certificaciones">
      <Certification lang="en" />
    </SectionContainer>
    <SectionContainer id="contacto">
      <Contact lang="en" />
    </SectionContainer>
  </main>
</Layout>